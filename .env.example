# --- FORMSPREE (obligatoire) ---------------------------------
# Crée un form sur https://formspree.io, récupère l'ID du form.
FORMSPREE_FORM_ID=xxxxxxxx

# --- Captcha Cloudflare Turnstile (recommandé en prod) -------
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
